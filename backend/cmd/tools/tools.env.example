# Backend tools environment example
# Copy this file to a local env file and fill in real values before running tools.

# Required: master database DSN used by most tools
PANTHEON_TOOL_MASTER_DSN=root:your-password@tcp(127.0.0.1:3306)/pantheon_master?charset=utf8mb4&parseTime=True&loc=Local

# Required: MySQL root-level DSN without fixed database, mainly for verify-conn
PANTHEON_TOOL_MYSQL_ROOT_DSN=root:your-password@tcp(127.0.0.1:3306)/?charset=utf8mb4&parseTime=True&loc=Local

# Required: master database fields used by setup-default-tenant
PANTHEON_TOOL_MASTER_DB_HOST=127.0.0.1
PANTHEON_TOOL_MASTER_DB_PORT=3306
PANTHEON_TOOL_MASTER_DB_NAME=pantheon_master
PANTHEON_TOOL_MASTER_DB_USER=root
PANTHEON_TOOL_MASTER_DB_PASSWORD=your-password

# Required: Redis address
PANTHEON_TOOL_REDIS_ADDR=127.0.0.1:6379

# Optional: Redis auth and db index
PANTHEON_TOOL_REDIS_PASSWORD=
PANTHEON_TOOL_REDIS_DB=0
