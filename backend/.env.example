# ====================================
# Pantheon Platform 环境变量配置示例
# ====================================
# 复制此文件为 .env 并填入实际的敏感信息
# ⚠️ 重要: .env 文件已在 .gitignore 中，不会被提交到版本控制
#
# 安全提示:
# 1. 使用强随机字符串生成密钥: openssl rand -base64 32
# 2. 不要在不同环境间共享密钥
# 3. 定期轮换敏感密钥
# 4. 在生产环境使用密钥管理服务 (如 AWS Secrets Manager)

# ====================================
# 核心配置
# ====================================
# 环境标识: development, staging, production
ENVIRONMENT=development

# 服务端口
SERVER_PORT=8080

# 运行模式: debug, release, test
SERVER_MODE=release

# ====================================
# 数据库配置
# ====================================
# 主数据库配置
MASTER_DB_TYPE=mysql
MASTER_DB_HOST=localhost
MASTER_DB_PORT=3306
MASTER_DB_DATABASE=pantheon_master
MASTER_DB_USERNAME=root
# ⚠️ 安全: 使用强密码，至少16个字符
MASTER_DB_PASSWORD=your_secure_db_password_here_minimum_16_chars

# 监控数据库配置 (如果使用)
MONITOR_DB_HOST=localhost
MONITOR_DB_PORT=3306
MONITOR_DB_DATABASE=pantheon_monitor
MONITOR_DB_USERNAME=root
MONITOR_DB_PASSWORD=your_monitor_db_password_here

# ====================================
# Redis 配置
# ====================================
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
# ⚠️ 安全: Redis 密码，生产环境必须设置
REDIS_PASSWORD=your_redis_password_here

# ====================================
# 安全配置
# ====================================
# JWT 密钥 - 必须！使用 openssl rand -base64 32 生成
# ⚠️ 安全: 至少32字节，生产环境必须使用强随机密钥
JWT_SECRET=your_jwt_secret_here_minimum_32_bytes_long_random_string

# JWT 访问令牌过期时间 (秒)
JWT_EXPIRES_IN=7200

# JWT 刷新令牌过期时间 (秒)
REFRESH_EXPIRY=604800

# 数据加密密钥 - 必须！必须恰好32字节
# ⚠️ 安全: 用于敏感数据加密，生产环境必须使用强随机密钥
ENCRYPTION_KEY=your_exact_32_byte_encryption_key_here_

# ====================================
# 多租户配置
# ====================================
# 启用多租户
ENABLE_MULTI_TENANT=true

# 默认租户ID (仅单租户模式使用)
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000

# 部署模式: private, paas, saas
DEPLOYMENT_MODE=saas

# 租户策略: single, dedicated, mixed
DEPLOYMENT_TENANT_STRATEGY=dedicated

# ====================================
# 默认管理员账户 (仅开发/测试环境)
# ====================================
# ⚠️ 安全: 生产环境必须设置 DEFAULT_ADMIN_ENABLED=false
DEFAULT_ADMIN_ENABLED=true
DEFAULT_ADMIN_USERNAME=admin
# ⚠️ 安全: 至少12个字符，包含大小写字母、数字和特殊字符
DEFAULT_ADMIN_PASSWORD=Admin@Pantheon2026
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_REAL_NAME=System Admin

# ====================================
# CORS 配置
# ====================================
# 允许的跨域来源 (逗号分隔)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# 允许的凭证
ALLOW_CREDENTIALS=true

# ====================================
# 邮件配置
# ====================================
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Pantheon Platform

# SMTP 配置
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=your_smtp_username
EMAIL_SMTP_PASSWORD=your_smtp_password
EMAIL_SMTP_USE_TLS=true

# SendGrid 配置 (如果使用)
EMAIL_SENDGRID_API_KEY=your_sendgrid_api_key

# 阿里云邮件配置
EMAIL_ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
EMAIL_ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
EMAIL_ALIYUN_REGION=cn-hangzhou

# ====================================
# 短信配置
# ====================================
SMS_ENABLED=false
SMS_PROVIDER=aliyun

# 阿里云短信配置
SMS_ALIYUN_ACCESS_KEY_ID=your_aliyun_sms_access_key_id
SMS_ALIYUN_ACCESS_KEY_SECRET=your_aliyun_sms_access_key_secret
SMS_ALIYUN_REGION=cn-hangzhou
SMS_ALIYUN_SIGN_NAME=your_sign_name

# 腾讯云短信配置
SMS_TENCENT_SECRET_ID=your_tencent_secret_id
SMS_TENCENT_SECRET_KEY=your_tencent_secret_key
SMS_TENCENT_REGION=ap-guangzhou
SMS_TENCENT_APP_ID=your_tencent_app_id
SMS_TENCENT_SIGN_NAME=your_sign_name

# Twilio 短信配置
SMS_TWILIO_ACCOUNT_SID=your_twilio_account_sid
SMS_TWILIO_AUTH_TOKEN=your_twilio_auth_token
SMS_TWILIO_FROM_NUMBER=+1234567890

# ====================================
# 存储配置
# ====================================
# 存储提供商: local, s3, oss, cos
STORAGE_PROVIDER=local
STORAGE_UPLOAD_DIR=uploads
STORAGE_BASE_URL=/uploads

# S3 配置 (如果使用 AWS S3 或兼容服务)
STORAGE_S3_BUCKET=your_bucket_name
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=your_s3_access_key
STORAGE_S3_SECRET_KEY=your_s3_secret_key
STORAGE_S3_ENDPOINT=https://s3.amazonaws.com

# ====================================
# 安全增强配置
# ====================================
# 启用双因素认证
SECURITY_ENABLE_2FA=true

# 最大并发会话数 (0 = 无限制)
SECURITY_MAX_CONCURRENT_SESSIONS=5

# 速率限制配置
SECURITY_RATE_LIMIT_ENABLED=true
SECURITY_RATE_LIMIT_REQUESTS_PER_MINUTE=100
SECURITY_RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ====================================
# 日志配置
# ====================================
# 日志级别: debug, info, warn, error
LOG_LEVEL=info
LOG_FILENAME=logs/app.log

# ====================================
# Swagger 文档配置
# ====================================
# 生产环境建议设置为 false
SWAGGER_ENABLED=true

# ====================================
# 数据库迁移配置
# ====================================
# 自动执行数据库迁移
AUTO_MIGRATE=true
# 仅执行迁移然后退出
MIGRATE_ONLY=false